{
  "name": "obsidian-js-runner",
  "version": "1.0.0",
  "description": "Obsidian plugin to run JavaScript inside Markdown notes",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@eslint/json": "^0.6.0",
    "@types/node": "^16.11.6",
    "esbuild": "^0.28.1",
    "eslint": "^9.0.0",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "is-builtin-module": "4.0.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0"
  }
}